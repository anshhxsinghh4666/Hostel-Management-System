generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  HOSTEL_ADMIN
  STAFF
  STUDENT
}

model User {
  id           String   @id @default(uuid())
  fullName     String
  email        String   @unique
  phone        String   @unique
  passwordHash String
  role         Role
  profileImage String?
  isActive     Boolean  @default(true)
  lastLogin    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  passwordResetTokens PasswordResetToken[]
  auditLogs           AuditLog[]

  @@index([role])
  @@index([isActive])
  @@index([createdAt])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([entity])
  @@index([action])
  @@index([createdAt])
}

enum HostelType {
  BOYS
  GIRLS
}

enum RoomStatus {
  AVAILABLE
  FULL
  MAINTENANCE
}

enum RoomType {
  SINGLE
  DOUBLE
  TRIPLE
  DORMITORY
}

enum AllocationStatus {
  ACTIVE
  TRANSFERRED
  VACATED
}

enum StudentStatus {
  ACTIVE
  INACTIVE
}

enum ComplaintCategory {
  ELECTRICAL
  PLUMBING
  INTERNET
  FURNITURE
  CLEANING
  OTHER
}

enum ComplaintPriority {
  LOW
  MEDIUM
  HIGH
}

enum ComplaintStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

model Complaint {
  id          String             @id @default(uuid())
  studentId   String
  category    ComplaintCategory
  subject     String
  description String
  priority    ComplaintPriority  @default(MEDIUM)
  status      ComplaintStatus    @default(PENDING)
  adminRemark String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([status])
  @@index([category])
}

model LeaveRequest {
  id               String      @id @default(uuid())
  studentId        String
  fromDate         DateTime
  toDate           DateTime
  reason           String
  emergencyContact String
  parentName       String
  status           LeaveStatus @default(PENDING)
  adminComment     String?
  createdAt        DateTime    @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([status])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
}

model Hostel {
  id               String     @id @default(uuid())
  hostelName       String
  hostelType       HostelType
  totalRooms       Int
  totalCapacity    Int
  occupiedCapacity Int        @default(0)
  createdAt        DateTime   @default(now())

  rooms  Room[]
  students Student[]

  @@unique([hostelName, hostelType])
}

model Room {
  id           String     @id @default(uuid())
  hostelId     String
  roomNumber   String
  floorNumber  Int
  capacity     Int
  occupiedBeds Int        @default(0)
  roomType     RoomType   @default(DOUBLE)
  roomStatus   RoomStatus @default(AVAILABLE)
  createdAt    DateTime   @default(now())

  hostel      Hostel           @relation(fields: [hostelId], references: [id], onDelete: Cascade)
  students    Student[]
  allocations RoomAllocation[]

  @@unique([hostelId, roomNumber])
  @@index([hostelId])
}

model RoomAllocation {
  id                 String           @id @default(uuid())
  studentId          String
  roomId             String
  allocatedDate      DateTime         @default(now())
  allocationStatus   AllocationStatus @default(ACTIVE)
  transferredDate    DateTime?
  vacatedDate        DateTime?
  createdAt          DateTime         @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  room    Room    @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([roomId])
  @@index([allocationStatus])
}

enum VisitorRequestStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum GatePassStatus {
  ACTIVE
  USED
  EXPIRED
  REVOKED
}

enum StayExtensionStatus {
  PENDING
  APPROVED
  REJECTED
}

model Visitor {
  id        String   @id @default(uuid())
  name      String
  mobile    String
  relation  String
  createdAt DateTime @default(now())

  requests VisitorRequest[]

  @@index([mobile])
}

model VisitorRequest {
  id            String               @id @default(uuid())
  studentId     String
  visitorId     String
  purpose       String
  visitDate     DateTime
  arrivalTime   String
  departureTime String
  status        VisitorRequestStatus @default(PENDING)
  remarks       String?
  createdAt     DateTime             @default(now())

  student  Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  visitor  Visitor   @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  gatePass GatePass?

  @@index([studentId])
  @@index([status])
  @@index([visitDate])
}

model GatePass {
  id         String         @id @default(uuid())
  requestId  String         @unique
  passNumber String         @unique
  qrToken    String         @unique
  validFrom  DateTime
  validTo    DateTime
  status     GatePassStatus @default(ACTIVE)
  createdAt  DateTime       @default(now())

  request       VisitorRequest  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  logs          VisitorLog[]
  stayExtension StayExtension?

  @@index([passNumber])
  @@index([qrToken])
  @@index([status])
}

model VisitorLog {
  id           String   @id @default(uuid())
  gatePassId   String
  checkInTime  DateTime?
  checkOutTime DateTime?
  createdAt    DateTime @default(now())

  gatePass GatePass @relation(fields: [gatePassId], references: [id], onDelete: Cascade)

  @@index([gatePassId])
  @@index([checkInTime])
}

model StayExtension {
  id                     String               @id @default(uuid())
  gatePassId             String               @unique
  requestedDepartureTime String
  reason                 String
  status                 StayExtensionStatus  @default(PENDING)
  createdAt              DateTime             @default(now())

  gatePass GatePass @relation(fields: [gatePassId], references: [id], onDelete: Cascade)

  @@index([gatePassId])
  @@index([status])
}

model Student {
  id                 String         @id @default(uuid())
  registrationNumber String         @unique
  firstName          String
  lastName           String
  gender             String
  email              String         @unique
  phone              String         @unique
  course             String
  year               Int
  guardianName       String
  guardianPhone      String
  address            String
  hostelId           String?
  roomId             String?
  checkInDate        DateTime?
  status             StudentStatus  @default(ACTIVE)
  createdAt          DateTime       @default(now())

  hostel          Hostel?           @relation(fields: [hostelId], references: [id], onDelete: SetNull)
  room            Room?             @relation(fields: [roomId], references: [id], onDelete: SetNull)
  allocations     RoomAllocation[]
  complaints      Complaint[]
  leaveRequests   LeaveRequest[]
  visitorRequests VisitorRequest[]
  payments        Payment[]

  @@index([hostelId])
  @@index([roomId])
  @@index([status])
}

enum PaymentMethod {
  CASH
  CARD
  UPI
  BANK_TRANSFER
  CHEQUE
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model Payment {
  id              String        @id @default(uuid())
  studentId       String
  amount          Decimal       @default(0)
  paymentDate     DateTime      @default(now())
  paymentMethod   PaymentMethod @default(CASH)
  status          PaymentStatus @default(PENDING)
  transactionId   String?
  remarks         String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([status])
  @@index([paymentDate])
}
